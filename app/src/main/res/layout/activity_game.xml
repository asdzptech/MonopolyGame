<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0E68C">

    <!-- 顶部信息栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#8B4513"
        android:padding="8dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/turnInfoText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="回合 1 - 玩家"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/diceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="#FFD700"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- 棋盘区域 -->
    <com.monopoly.game.ui.BoardView
        android:id="@+id/boardView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="8dp"/>

    <!-- 玩家信息区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#DEB887"
        android:padding="8dp">

        <TextView
            android:id="@+id/playerInfoText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="#654321"
            android:maxLines="4"/>

    </LinearLayout>

    <!-- 消息区域 -->
    <TextView
        android:id="@+id/messageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="欢迎来到大富翁！"
        android:textSize="16sp"
        android:textColor="#8B0000"
        android:gravity="center"
        android:background="#FFF8DC"
        android:padding="12dp"
        android:textStyle="bold"/>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#8B4513"
        android:padding="8dp"
        android:gravity="center">

        <Button
            android:id="@+id/backToMenuButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="菜单"
            android:textSize="14sp"
            android:backgroundTint="#708090"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/rollDiceButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.5"
            android:text="掷骰子"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#228B22"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/buyButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="购买"
            android:textSize="14sp"
            android:backgroundTint="#4169E1"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/skipButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="跳过"
            android:textSize="14sp"
            android:backgroundTint="#FF8C00"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/endTurnButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="结束"
            android:textSize="14sp"
            android:backgroundTint="#DC143C"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>
